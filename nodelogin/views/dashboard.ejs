<p class="lead mb-3">Welcome <%= user.name %></p>
<a href="/users/logout" class="btn btn-secondary">Logout</a>
<div class="row mt-5">
	<div class="col-md-6 m-auto">
		<div class="card card-body">
			<h1 class="text-center mb-3">Fake News Detector</h1>
			<form id="form">
				<div class="form-group">
					<label for="email">Enter News Article Link</label>
					<input type="text" id="article-link" name="link" class="form-control" placeholder="Enter Link" />
				</div>
				<button type="submit" class="btn btn-primary btn-block">Predict</button>
				<div id="response"></div>
			</form>
		</div>
	</div>
</div>
